# ===================================
# .gitattributes
# Ensure consistent line endings and file handling
# ===================================

# Auto-detect text files and normalize to LF on commit
* text=auto

# ===================================
# Source Code
# ===================================
*.c     text diff=cpp
*.cpp   text diff=cpp
*.h     text diff=cpp
*.hpp   text diff=cpp
*.ino   text diff=cpp
*.py    text diff=python
*.js    text
*.json  text
*.md    text diff=markdown
*.txt   text
*.xml   text
*.yml   text
*.yaml  text

# ===================================
# Configuration Files
# ===================================
*.ini   text
*.cfg   text
*.conf  text
*.csv   text
.gitattributes text
.gitignore     text
.editorconfig  text

# ===================================
# Documentation
# ===================================
*.markdown text diff=markdown
*.mdown    text diff=markdown
*.mkd      text diff=markdown
*.mdx      text diff=markdown

# ===================================
# Shell Scripts (LF only)
# ===================================
*.sh    text eol=lf
*.bash  text eol=lf

# ===================================
# Windows Specific (CRLF)
# ===================================
*.bat   text eol=crlf
*.cmd   text eol=crlf

# ===================================
# Binary Files (no text conversion)
# ===================================
*.bin   binary
*.elf   binary
*.hex   binary
*.a     binary
*.so    binary
*.o     binary

# Images
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary

# Fonts
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary

# Archives
*.zip   binary
*.gz    binary
*.tar   binary
*.rar   binary
*.7z    binary

# Documents
*.pdf   binary
*.doc   binary
*.docx  binary

# ===================================
# ESP32 / PlatformIO Specific
# ===================================
*.map   text
platformio.ini text

# ===================================
# Git LFS (Large File Storage) - если нужно
# ===================================
# *.bin filter=lfs diff=lfs merge=lfs -text
# *.elf filter=lfs diff=lfs merge=lfs -text

# ===================================
# Linguist Language Detection
# (для правильной статистики GitHub)
# ===================================
*.ino linguist-language=C++
*.html linguist-vendored=false
docs/* linguist-documentation
examples/* linguist-documentation
