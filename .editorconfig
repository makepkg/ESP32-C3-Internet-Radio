# ===================================
# EditorConfig
# Coding style consistency across editors
# https://editorconfig.org
# ===================================

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# C/C++ files
[*.{c,cpp,h,hpp,ino}]
indent_style = space
indent_size = 4
max_line_length = 120

# Python files
[*.py]
indent_style = space
indent_size = 4
max_line_length = 120

# Web files
[*.{html,css,js,json}]
indent_style = space
indent_size = 2

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Makefiles
[Makefile]
indent_style = tab

# Shell scripts
[*.{sh,bash}]
indent_style = space
indent_size = 2
end_of_line = lf

# Batch files
[*.{bat,cmd}]
end_of_line = crlf

# PlatformIO
[platformio.ini]
indent_style = space
indent_size = 2

# Git files
[.gitattributes]
indent_style = space
indent_size = 2

[.gitignore]
indent_style = space
indent_size = 2
